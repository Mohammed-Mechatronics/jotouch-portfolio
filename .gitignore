__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.mypy_cache/

# Virtual environments
.venv/
venv/
env/

# IDE / OS
.vscode/
.idea/
.DS_Store
Thumbs.db

# Local-only directories
_archive/
models/

# Logs
*.log

# LED calibration output (machine-local)
led_roi.json

# BIDS data — raw, processed, and results are gitignored
# Only data/sample/ is tracked (curated demo subset)
data/raw/*
!data/raw/.gitkeep
!data/raw/dataset_description.json
!data/raw/participants.tsv
!data/raw/sessions.tsv
data/processed/*
!data/processed/.gitkeep
data/results/*
!data/results/.gitkeep

# Large unified session record (387 MB) — regenerate via promote_to_sample.py
data/sample/sub-P01/ses-S01/sub-P01_ses-S01_record.csv
data/sample/sub-P01/ses-S01/sub-P01_ses-S01_record.json

# Derived ML data (regenerate via extract_ml_data.py)
data/derived/

# Split results (regenerate via apply_splits.py — only specs are tracked)
data/splits/results/

# Validation runs (regenerate via the validation framework)
validation_results/

# CV review scratch folder (not project work)
_cv_review/
